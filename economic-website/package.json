{
  "name": "economic-website",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run start:dev",
    "build": "npm --workspaces run build",
    "lint": "npm --workspaces run lint",
    "db:generate": "npm --workspace apps/api run prisma:generate",
    "db:migrate": "npm --workspace apps/api run prisma:migrate"
  },
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
